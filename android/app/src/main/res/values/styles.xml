<resources>
  <style name="AppTheme" parent="Theme.AppCompat.NoActionBar">
    <item name="android:fontFamily">sans</item>
    <item name="android:windowBackground">@color/pc_paper</item>
    <item name="android:colorAccent">@color/pc_accent</item>
    <item name="android:forceDarkAllowed">false</item>
    <item name="android:windowLightStatusBar">true</item>
    <item name="android:windowLightNavigationBar">true</item>
    <item name="android:navigationBarColor">@color/pc_paper</item>
    <item name="android:statusBarColor">@color/pc_paper</item>
  </style>

  <!-- Cold-start splash: bear mark on paper. MainActivity swaps to AppTheme in
       onCreate once React Native mounts. -->
  <style name="AppTheme.Splash" parent="AppTheme">
    <item name="android:windowBackground">@drawable/splashscreen</item>
  </style>
</resources>
