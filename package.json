{
  "name": "precious-captures",
  "version": "0.1.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "build": "next build",
    "test": "npm run typecheck && npm run validate:intents && npm run test:unit",
    "test:unit": "node --test test/*.test.js",
    "test:url-evidence": "deno test --config supabase/functions/capture-intake/deno.json --allow-env supabase/functions/capture-intake/*.test.ts",
    "test:e2e:maestro": "node scripts/run-maestro-smoke.mjs",
    "test:e2e:android-share": "node scripts/run-android-share-smoke.mjs",
    "test:e2e:hosted": "npm run hosted:verify -- --allow-no-reminder && npm run hosted:verify:review",
    "start": "react-native start",
    "android:build": "node scripts/with-android-dev-env.mjs --cwd android ./gradlew :app:assembleDebug",
    "android:build:hosted": "node scripts/build-hosted-apk.mjs",
    "android:build:release": "cd android && ./gradlew :app:assembleRelease",
    "android:install:debug": "adb install --no-streaming -r android/app/build/outputs/apk/debug/app-debug.apk",
    "android:install": "adb install -r android/app/build/outputs/apk/release/app-release.apk",
    "android:install:wifi": "node scripts/install-android-wifi.mjs",
    "android:push:wifi": "npm run android:build:hosted && npm run android:install:wifi",
    "android:launch": "adb shell am start -n com.preciouscaptures/.MainActivity",
    "android:reverse:metro": "adb reverse tcp:8081 tcp:8081",
    "android:reverse": "adb reverse tcp:3030 tcp:3030",
    "android:dev:install": "npm run android:build && npm run android:install:debug",
    "android:dev:reverse": "npm run android:reverse:metro && npm run android:reverse",
    "android:dev:launch": "npm run android:dev:reverse && npm run android:launch",
    "android:dev": "npm run android:dev:reverse && node scripts/with-android-dev-env.mjs npm run start",
    "android:share": "adb shell am start -a android.intent.action.SEND -t text/plain --es android.intent.extra.TEXT 'https://www.nps.gov/yose/planyourvisit/index.htm' -n com.preciouscaptures/.ShareIntakeActivity",
    "hosted:deploy": "node scripts/deploy-hosted-function.mjs",
    "hosted:db:push": "node scripts/push-supabase-db.mjs",
    "hosted:create-user": "node scripts/create-password-user.mjs",
    "hosted:verify": "node scripts/verify-hosted-capture.mjs",
    "hosted:verify:review": "node scripts/verify-review-regression.mjs",
    "eval:exa:generate": "node scripts/generate-exa-corpus.mjs",
    "eval:private:export": "node scripts/export-private-capture-eval.mjs",
    "eval:label:preflight": "node scripts/label-silver-gemini.mjs --preflight --limit 1",
    "eval:label:silver": "node scripts/label-silver-gemini.mjs",
    "eval:capture:run": "node scripts/run-capture-eval.mjs",
    "eval:review:queue": "node scripts/generate-review-queue.mjs",
    "eval:review:gold:build": "node scripts/build-gold-labels-from-review.mjs",
    "eval:review:gold:v2-collections": "node scripts/build-gold-v2-collections.mjs",
    "eval:combined:build": "node scripts/build-combined-eval-labels.mjs",
    "eval:capture:score": "node scripts/score-capture-eval.mjs",
    "server:dev": "node server/index.mjs",
    "typecheck": "tsc --noEmit",
    "validate:intents": "node scripts/validate-save-intents.mjs",
    "hosted:inspect": "node scripts/inspect-supabase-state.mjs",
    "hosted:reset": "node scripts/reset-hosted-project.mjs --yes"
  },
  "dependencies": {
    "@expo/ui": "^56.0.15",
    "@supabase/supabase-js": "^2.106.2",
    "expo": "^56.0.4",
    "expo-image": "^56.0.9",
    "next": "^16.2.6",
    "phosphor-react-native": "^3.0.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "^0.85.3",
    "react-native-svg": "15.15.5",
    "react-native-url-polyfill": "^3.0.0"
  },
  "devDependencies": {
    "@react-native-community/cli": "^20.1.3",
    "@react-native/metro-config": "^0.85.3",
    "@types/react": "^19.2.15",
    "typescript": "^5.8.3"
  }
}
