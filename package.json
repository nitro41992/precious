{
  "name": "precious-captures",
  "version": "0.1.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "build": "next build",
    "test": "npm run typecheck && npm run validate:intents && npm run test:unit",
    "test:unit": "node --test test/*.test.js",
    "test:e2e:maestro": "node scripts/run-maestro-smoke.mjs",
    "test:e2e:android-share": "node scripts/run-android-share-smoke.mjs",
    "test:e2e:hosted": "npm run hosted:verify -- --allow-no-reminder && npm run hosted:verify:review",
    "android:build": "cd android && ./gradlew :app:assembleDebug",
    "android:build:hosted": "node scripts/build-hosted-apk.mjs",
    "android:build:release": "cd android && ./gradlew :app:assembleRelease",
    "android:install": "adb install -r android/app/build/outputs/apk/release/app-release.apk",
    "android:launch": "adb shell am start -n com.preciouscaptures/.MainActivity",
    "android:reverse": "adb reverse tcp:3030 tcp:3030",
    "android:share": "adb shell am start -a android.intent.action.SEND -t text/plain --es android.intent.extra.TEXT 'https://www.nps.gov/yose/planyourvisit/index.htm' -n com.preciouscaptures/.ShareIntakeActivity",
    "hosted:deploy": "node scripts/deploy-hosted-function.mjs",
    "hosted:db:push": "node scripts/push-supabase-db.mjs",
    "hosted:create-user": "node scripts/create-password-user.mjs",
    "hosted:verify": "node scripts/verify-hosted-capture.mjs",
    "hosted:verify:review": "node scripts/verify-review-regression.mjs",
    "server:dev": "node server/index.mjs",
    "typecheck": "tsc --noEmit",
    "validate:intents": "node scripts/validate-save-intents.mjs",
    "hosted:inspect": "node scripts/inspect-supabase-state.mjs",
    "hosted:reset": "node scripts/reset-hosted-project.mjs --yes"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.106.2",
    "expo": "^56.0.4",
    "lucide-react-native": "1.17.0",
    "next": "^16.2.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "^0.85.3",
    "react-native-svg": "15.15.5",
    "react-native-url-polyfill": "^3.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.15",
    "typescript": "^5.8.3"
  }
}
