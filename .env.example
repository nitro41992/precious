EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Optional. If omitted, the Android app uses:
# ${EXPO_PUBLIC_SUPABASE_URL}/functions/v1/capture-intake
PRECIOUS_CAPTURE_FUNCTION_URL=https://YOUR_PROJECT.supabase.co/functions/v1/capture-intake

# Required for deploying Supabase functions if you do not run `npx supabase login`.
SUPABASE_ACCESS_TOKEN=

# Required by local verification and user-management scripts.
SUPABASE_SERVICE_ROLE_KEY=
PRECIOUS_E2E_PASSWORD=

# Set this in Supabase Secrets for production Edge Functions.
# Keep a local copy only if you need scripts to sync or inspect secrets.
OPENAI_API_KEY=

# Optional override for Edge Function analysis model.
OPENAI_MODEL=gpt-5-mini
